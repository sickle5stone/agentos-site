{
  "name": "agentos-site",
  "version": "1.0.0",
  "private": true,
  "description": "Marketing site for agentOS. Static HTML with a compiled Tailwind stylesheet.",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i input.css -o dist.css --minify",
    "watch:css": "tailwindcss -c tailwind.config.js -i input.css -o dist.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "0.1.1",
    "@tailwindcss/forms": "0.5.9",
    "tailwindcss": "3.4.17"
  }
}
